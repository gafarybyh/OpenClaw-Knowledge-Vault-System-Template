# OpenClaw Knowledge Vault - Environment Configuration
# Copy this file to .env and fill in your API keys and preferences

# --- General Settings ---
# Delay between AI requests in milliseconds (Default: 200)
AI_REQUEST_DELAY=500

# ---------------------------------------------------------
# 1. PRIMARY AI (OpenAI Compatible)
# ---------------------------------------------------------
PRIMARY_AI_URL=https://api.cerebras.ai/v1/chat/completions
PRIMARY_AI_MODEL=gpt-oss-120b
PRIMARY_AI_KEY=your_primary_ai_api_key_here

# ---------------------------------------------------------
# 2. FALLBACK AI (OpenAI Compatible)
# ---------------------------------------------------------
FALLBACK_AI_URL=https://generativelanguage.googleapis.com/v1beta/chat/completions
FALLBACK_AI_MODEL=gemini-2.5-flash
FALLBACK_AI_KEY=your_fallback_ai_api_key_here

# ---------------------------------------------------------
# 3. EMBEDDING
# ---------------------------------------------------------
EMBEDDING_URL=http://localhost:11434/api/embed
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_KEY=your_embedding_api_key_here

# ---------------------------------------------------------
# 4. LINKER & GRAPH CONFIGURATION
# Adjust these parameters to fine-tune the behavior of the semantic linker and graph construction.
# ---------------------------------------------------------
SIMILARITY_THRESHOLD=0.72
MAX_CANDIDATES_PER_FILE=5
PRE_FILTER_MIN_SHARED=1
EMBEDDING_BATCH_SIZE=5
MAX_RETRIES=3

# ---------------------------------------------------------
# 5. GRAPH SEARCH CONFIGURATION
# Adjust these parameters to fine-tune the graph search
# ---------------------------------------------------------
SEMANTIC_THRESHOLD=0.3
TOP_K=5
MAX_NODES=10
HUB_DEGREE_LIMIT=25
